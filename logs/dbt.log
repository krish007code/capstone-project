    create  table
      "capstone_dev"."main"."fct_orders__dbt_tmp"
  
    as (
      

with  __dbt__cte__int_order_items_joined as (


with items as (
    select * from "capstone_dev"."main"."stg_items"
),

orders as (
    select * from "capstone_dev"."main"."stg_orders"
),

products as (
    select * from "capstone_dev"."main"."stg_products"
),

joined as (
    select
        items.item_id,
        items.order_id,
        items.product_id,
        orders.customer_id,
        orders.store_id,
        products.product_price as item_revenue,
        products.product_cost as item_cost
    from items 
    left join orders 
        on items.order_id = orders.id 
    left join products 
        on items.product_id = products.product_id
)

select * from joined
), order_items as (
    select * from __dbt__cte__int_order_items_joined
),

order_aggregations as (
    select
        order_id,
        customer_id,
        store_id,
        orders_at,
        
        -- Calculate total metrics per individual order
        sum(item_revenue) as total_revenue,
        sum(item_cost) as total_cost,
        sum(item_revenue) - sum(item_cost) as total_profit
        
    from order_items
    group by 
        order_id,
        customer_id,
        store_id,
        orders_at
)

select * from order_aggregations
    );
  
  
