    create  table
      "capstone_dev"."main"."dim_stores__dbt_tmp"
  
    as (
      

with  __dbt__cte__int_product_sales_aggregated as (


with products as(
    select * from products
),
items as(
    select * from items
),
item_margin as(
    select
        products.product_id,
        products.price - products.cost as product_margin,
        items.order_id 
    from items left join products on products.product_id = items.product_id
),
aggregated as(
    select
        product_id,
        count(*) as total_sold,
        sum(item_revenue) as gross_revenue,
        sum(item_revenue - item_cost) as total_profit
        from item_margins
    group by product_id
)
select * from aggregated
), stores as (
    select * from "capstone_dev"."main"."stg_stores"
),
store_financials as (
    select * from __dbt__cte__int_product_sales_aggregated
),
final as (
    select
        stores.store_id,
        stores.store_name,
        coalesce(store_financials.total_revenue, 0) as total_revenue,
        coalesce(store_financials.total_cost, 0) as total_cost,
        coalesce(store_financials.total_profit, 0) as total_profit,
        
        case 
            when store_financials.total_revenue > 0 
            then round((store_financials.total_profit / store_financials.total_revenue) * 100, 2)
            else 0 
        end as profit_margin_pct

    from stores
    left join store_financials
        on stores.store_id = store_financials.store_id
)
select * from final
    );
  
  
